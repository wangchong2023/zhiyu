# Fastfile
#
# 作者: Wang Chong
# 功能说明: ZhiYu Fastlane 自动化任务定义
#          仅负责驱动 xcodebuild 测试——SwiftLint 已由 CI 流水线独立 step 负责
# 版本: 2.0
# 日期: 2026-06-07
#
# 变更 (v2.0):
#   - 移除 ci_test 中的 SwiftLint（避免与 CI SwiftLint --strict step 重复执行）
#   - 移除 rescue 吞错逻辑（错误应向上传播，由 CI 统一处理）
#   - lane 更名 ci_test → run_tests，职责单一化

default_platform(:ios)

platform :ios do
  desc "驱动 xcodebuild 执行全量单元/集成测试并收集覆盖率"
  lane :run_tests do
    scan(
      project: "ZhiYu.xcodeproj",
      scheme: "ZhiYu",
      device: "iPhone 17 Pro",
      code_coverage: true,
      clean: true,
      derived_data_path: "build/DerivedData"
    )
  end
end
