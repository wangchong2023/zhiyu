{
  "id": "com.zhiyu.plugin.local.word-counter",
  "version": "1.0.0",
  "author": "ZhiYu Local Team",
  "permissions": [
    "readContent",
    "log"
  ],
  "allowedDomains": [],
  "names": {
    "en": "Word Counter",
    "zh-Hans": "字数统计"
  },
  "descriptions": {
    "en": "Real-time word and character counting for Markdown documents with detailed statistics.",
    "zh-Hans": "实时统计 Markdown 文档的字数、字符数，提供详细的统计信息。"
  },
  "iconFile": "icon.png",
  "readmeFiles": {
    "en": "README.md",
    "zh-Hans": "README.zh-Hans.md"
  },
  "category": "built-in",
  "inputSchema": {
    "type": "object",
    "properties": {
      "content": {
        "type": "string",
        "description": "Markdown document content"
      }
    }
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "words": {
        "type": "integer",
        "description": "Word count"
      },
      "characters": {
        "type": "integer",
        "description": "Character count"
      },
      "paragraphs": {
        "type": "integer",
        "description": "Paragraph count"
      }
    }
  },
  "source": "local"
}