{
  "id": "com.zhiyu.plugin.remote.link-preview",
  "version": "1.0.0",
  "author": "ZhiYu Remote Team",
  "permissions": [
    "readContent",
    "writeContent",
    "network",
    "log"
  ],
  "allowedDomains": [
    "*"
  ],
  "names": {
    "en": "Link Preview",
    "zh-Hans": "链接预览"
  },
  "descriptions": {
    "en": "Automatically fetches URL meta information and generates rich preview cards with images and descriptions.",
    "zh-Hans": "自动获取 URL 的 meta 信息，生成包含图片和描述的丰富预览卡片。"
  },
  "iconFile": "icon.png",
  "readmeFiles": {
    "en": "README.md",
    "zh-Hans": "README.zh-Hans.md"
  },
  "category": "community",
  "inputSchema": {
    "type": "object",
    "properties": {
      "url": {
        "type": "string",
        "description": "URL to fetch preview for"
      }
    }
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "title": {
        "type": "string",
        "description": "Page title"
      },
      "description": {
        "type": "string",
        "description": "Meta description"
      },
      "image": {
        "type": "string",
        "description": "OG image URL"
      }
    }
  },
  "source": "remote"
}