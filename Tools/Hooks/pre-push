#!/bin/bash
# ==============================================================================
# 脚本名称: pre-push
# 核心职责: 推送前调用统一门禁脚本，执行全面检查。
# 详细逻辑: Tools/pre_push_check.sh
# ==============================================================================

# 默认模式：静态检查 + 编译校验
# 如需完整检查（含测试+覆盖率），设置环境变量: FULL_CHECK=1 git push
# 如需快速检查（仅静态），设置环境变量: QUICK_CHECK=1 git push

MODE_ARG=""
if [ "${FULL_CHECK:-0}" = "1" ]; then
    MODE_ARG="--full"
elif [ "${QUICK_CHECK:-0}" = "1" ]; then
    MODE_ARG="--quick"
fi

exec bash Tools/pre_push_check.sh $MODE_ARG
