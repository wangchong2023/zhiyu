      "extractionState": "manual"
    },
    "dashboard.insight.tips.content": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Based on this week's knowledge growth, it is recommended to continue exploring connections in related fields and try to connect fragmented knowledge points through mindmaps."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "基于本周的知识增长情况，建议你继续深入探索相关领域的关联，并尝试通过思维导图将零散的知识点串联起来。"
          }
        }
      },
      "extractionState": "manual"
    },
    "dashboard.insight.tips.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deep Insights"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "深度建议"
          }
        }
      },
      "extractionState": "manual"
    },
    "dashboard.insight.weekly.prompt": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "# Role: Senior Knowledge Architect\n# Context: User added nodes: [%@].\n# Task: Generate a weekly report, including cognitive anchors, connection density, etc. Requirement: Within 250 words."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "# Role: 资深知识架构师\n# Context: 用户添加了节点：[%@]。\n# Task: 生成周度报告，包含认知锚点、关联密度等。要求 250 字以内。"
          }
        }
      },
      "extractionState": "manual"
    },
    "dashboard.insight.weekly.systemPrompt": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
