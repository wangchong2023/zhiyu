      },
      "extractionState": "manual"
    },
    "dashboard.insight.growth.explosive": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Explosive Growth"
          }
        },
        "zh-Hans": {
          "stringUnit": {
