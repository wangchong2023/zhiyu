    "dashboard.insight.recap.tip": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap to see more connection suggestions"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击查看更多关联建议"
          }
        }
