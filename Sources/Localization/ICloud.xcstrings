    "icloud.pullOverwriteMessage": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All local pages will be replaced by remote data, this action cannot be undone."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "所有本地页面将被远程数据替换，此操作不可撤销。"
          }
        }
      }
    },
    "icloud.pullWillOverwrite": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Downloading from iCloud will overwrite local data"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从 iCloud 下载将覆盖本地数据"
          }
        }
      }
    },
    "icloud.pushToCloud": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
