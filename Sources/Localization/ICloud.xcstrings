    "icloud.conflictDetected": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Conflict Detected"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "冲突检测"
          }
        }
      }
    },
    "icloud.conflictMessage": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Local and remote data have conflicts. Please choose a resolution."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "本地与远程数据存在冲突，请选择解决方式。"
          }
        }
      }
    },
    "icloud.conflictPolicy": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Conflict Resolution Policy"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "冲突解决策略"
          }
        }
      }
    },
