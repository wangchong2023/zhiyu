    "icloud.error.notAvailable": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud unavailable. Please sign in to your iCloud account."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud 不可用，请确认已登录 iCloud 账户"
          }
        }
      }
    },
    "icloud.info1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Data is stored via iCloud private database"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "数据通过 iCloud 私有数据库存储"
          }
        }
      }
    },
    "icloud.info2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sync only between devices with the same Apple ID"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅限同一 Apple ID 的设备间同步"
          }
        }
      }
    },
    "icloud.info3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Defaults to merging data from both sides on conflict"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "冲突时默认合并两边数据"
          }
        }
      }
    },
    "icloud.info4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pages use update time, keeping the newer version"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "页面以更新时间为准，保留较新版本"
          }
        }
      }
    },
    "icloud.keepLocal": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep Local"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保留本地"
          }
        }
      }
    },
    "icloud.keepRemote": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep Remote"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "保留远程"
          }
        }
      }
    },
    "icloud.lastSyncFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Last sync: %@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "上次同步：%@"
          }
        }
      }
    },
