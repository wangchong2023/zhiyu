    "icloud.clearCloudDataMessage": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "All data in your iCloud private database will be deleted. This cannot be undone."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您在 iCloud 私有数据库中的所有数据将被清除，此操作无法撤销。"
