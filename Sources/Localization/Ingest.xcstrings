    "ingest.deepScanDesc": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Full vector search across vault to discover potential links between new and old knowledge."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对知识库进行全量向量化检索，自动发现新旧知识点之间的潜在关联。"
          }
        }
      },
      "extractionState": "manual"
    },
    "ingest.ecoIndexingLowPower": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "🔋 [Eco-Indexing] 系统处于低功耗模式，将采用节流索引策略。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Low Power Mode Indexing"
          }
        }
      },
      "extractionState": "manual"
    },
    "ingest.enrichRichContentPrompt": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "# Role: 知识工程专家\n\n# Task: \n分析以下 Markdown 内容，识别其中的表格 (|---|) 和图片 (![]())。\n\n# Requirements:\n1. 对于每个表格，基于其行列数据生成一段 150 字以内的“数据洞察摘要”。\n2. 对于每个核心图片，基于标题或上下文推测其视觉语义。\n3. 将这些分析结果以 `> [Semantic Insight]: ...` 的格式插入到原图表下方。\n4. 保持原文逻辑不变，仅返回增强后的完整 Markdown 内容。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "# Role: 知识工程专家\n\n# Task: \n分析以下 Markdown 内容，识别其中的表格 (|---|) 和图片 (![]())。\n\n# Requirements:\n1. 对于每个表格，基于其行列数据生成一段 150 字以内的“数据洞察摘要”。\n2. 对于每个核心图片，基于标题或上下文推测其视觉语义。\n3. 将这些分析结果以 `> [Semantic Insight]: ...` 的格式插入到原图表下方。\n4. 保持原文逻辑不变，仅返回增强后的完整 Markdown 内容。"
          }
        }
      },
      "extractionState": "manual"
    },
