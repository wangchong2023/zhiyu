{
  "sourceLanguage": "en",
  "strings": {
    "onboarding.action.next": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Next"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下一步"
          }
        }
      }
    },
    "onboarding.action.skip": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Skip"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "跳过"
          }
        }
      }
    },
    "onboarding.action.start": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get Started"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "立即开始"
          }
        }
      }
    },
    "onboarding.step.aiLab.desc": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deeply integrated AI assistant supports smart summary, quiz generation, linting, and automated synthesis."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "内置深度集成的 AI 助手，支持智能摘要、测验生成、语法修复及自动化知识合成。"
          }
        }
      }
    },
    "onboarding.step.aiLab.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "AI-Native Collaboration"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "AI 原生协作"
          }
        }
      }
    },
    "onboarding.step.graph.desc": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Discover hidden links between knowledge and visualize your thought trajectory via interactive 2D/3D graphs."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过交互式 2D/3D 图谱，直观洞察知识之间的隐藏关联，发现思想的成长轨迹。"
          }
        }
      }
    },
    "onboarding.step.graph.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Visual Knowledge Graph"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可视化知识图谱"
          }
        }
      }
    },
    "onboarding.step.linking.desc": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use [[title]] syntax to create semantic links between pages, letting fragmented info flow and aggregate naturally."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用 [[标题]] 语法，在不同页面之间建立语义关联，让碎片化的信息自然流动、聚合。"
          }
        }
      }
    },
    "onboarding.step.linking.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Power of Backlinking"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "双向链接的力量"
          }
        }
      }
    },
    "onboarding.step.vault.desc": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Now, start entering your first piece of knowledge and let your wisdom take root in ZhiYu."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "现在，开始录入您的第一条知识，让您的智慧在“智宇”中生根发芽。"
          }
        }
      }
    },
    "onboarding.step.vault.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Start Your Journey"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启您的智慧之旅"
          }
        }
      }
    },
    "onboarding.step.welcome.desc": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ZhiYu is an LLM-powered second brain tool designed to help you build a structured knowledge vault via backlinking and graph technology."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "智宇是一款基于 LLM 的第二大脑工具，旨在通过双向链接和图谱技术，帮助您构建结构化的个人知识体系。"
          }
        }
      }
    },
    "onboarding.step.welcome.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Welcome to %@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "欢迎来到 %@"
          }
        }
      }
    },
    "welcome.demo.desc": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One-click inject to experience Graph & AI Synthesis"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一键注入示例，快速体验图谱与 AI 合成"
          }
        }
      }
    },
    "welcome.demo.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Explore AI Agent Demo Data"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "探索 AI 代理演示数据"
          }
        }
      }
    },
    "welcome.desc1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "is an AI-native knowledge evolution engine. It doesn't just store notes, it helps discover hidden links via the"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "是一个“AI 原生”的知识进化引擎。它不仅能帮您存储笔记，还能通过"
          }
        }
      }
    },
    "welcome.desc2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "发现知识间的隐秘联系。"
          }
        }
      }
    },
    "welcome.growthTrend": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Knowledge Growth Trend"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "知识增长趋势"
          }
        }
      }
    },
    "welcome.guide.browseGraph": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Browse knowledge connections in the graph"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在图谱中浏览知识关联"
          }
        }
      }
    },
    "welcome.guide.createPage": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create your first knowledge node"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "创建你的第一个知识节点"
          }
        }
      }
    },
    "welcome.guide.knowledgeLink": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use [[Backlinks]] to connect knowledge"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用 [[双链]] 建立知识关联"
          }
        }
      }
    },
    "welcome.guide.search": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Quickly find content through search"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过搜索快速定位内容"
          }
        }
      }
    },
    "welcome.header": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Welcome to your second brain"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "欢迎来到您的第二大脑"
          }
        }
      }
    },
    "welcome.knowledgelinkHint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Type [[Page Name]] in the editor to automatically create bidirectional links"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "编辑页面时输入 [[页面名]] 即可自动建立双向链接"
          }
        }
      }
    },
    "welcome.quickStart": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick Start Guide"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "新手快速入门"
          }
        }
      }
    },
    "welcome.start1": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Try clicking the"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "尝试点击右侧的"
          }
        }
      }
    },
    "welcome.start2": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "button and ask: 'What's in my library?'"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按钮，问我：“我库里有哪些内容？”"
          }
        }
      }
    },
    "welcome.start3": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Drag a PDF into the 'Import' page to experience AI auto-decomposition."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "拖入一个 PDF 到“导入”页面，体验 AI 自动拆解。"
          }
        }
      }
    },
    "welcome.start4": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Type `[[` on any page to try creating a link."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在任意页面输入 `[[` 尝试创建链接。"
          }
        }
      }
    },
    "welcome.startTitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
