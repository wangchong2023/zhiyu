    },
    "model_manager.alert.oom_message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Model %1$@ requires %2$@ GB memory. Your device only has %3$@ GB memory."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "模型 %1$@ 需要至少 %2$@ GB 内存，您的设备当前仅有 %3$@ GB，有极高概率发生闪退。"
          }
        }
      }
    },
