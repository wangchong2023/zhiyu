    "NSMicrophoneUsageDescription": {
      "comment": "Privacy - Microphone Usage Description",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "ZhiYu needs microphone access to record voice notes."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "智宇需要访问您的麦克风，以便录制语音笔记。"
          }
        }
      }
    },
    "NSPhotoLibraryUsageDescription": {
      "comment": "Privacy - Photo Library Usage Description",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "ZhiYu needs photo library access for OCR text scanning."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "智宇需要访问您的照片图库，以便导入图片并进行 OCR 文本扫描识别。"
          }
        }
      }
    },
    "NSRemindersFullAccessUsageDescription": {
      "comment": "Privacy - Reminders Full Access Usage Description",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "ZhiYu needs full access to reminders to create and manage task lists for your knowledge workflows."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "智宇需要完全访问您的提醒事项，以为您的知识工作流创建和管理任务清单。"
          }
        }
      }
    },
    "NSRemindersUsageDescription": {
      "comment": "Privacy - Reminders Usage Description",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "ZhiYu needs reminders access to sync your action items to the system Reminders app."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "智宇需要访问您的提醒事项，以将待办事项同步至系统的提醒事项应用中。"
          }
        }
      }
    },
    "NSSpeechRecognitionUsageDescription": {
      "comment": "Privacy - Speech Recognition Usage Description",
      "extractionState": "extracted_with_value",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "ZhiYu needs speech recognition to transcribe your voice notes."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "智宇需要访问您的语音识别功能，以将您的语音笔记转写为文本。"
          }
        }
      }
    }
  },
  "version": "1.0"
