    "security.database.corrupted": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Security connection failed. Reverted to transient read-only memory mode. New changes will be discarded on relaunch! Please check credentials or re-verify."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "安全连接失败。已自动降级为只读瞬态内存模式，重启后新增数据将丢失！请检查设备安全凭证并尝试重新验证。"
          }
        }
      }
    },
    "security.database.retry": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Re-verify"
