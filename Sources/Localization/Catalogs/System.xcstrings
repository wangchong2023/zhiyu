    "onboarding.step.welcome.desc": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ZhiYu is an LLM-powered second brain tool designed to help you build a structured knowledge vault via backlinking and graph technology."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "智宇是一款基于 LLM 的第二大脑工具，旨在通过双向链接和图谱技术，帮助您构建结构化的个人知识体系。"
          }
        }
      }
    },
