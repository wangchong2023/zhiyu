    "onboarding.step.aiLab.desc": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Deeply integrated AI assistant supports smart summary, quiz generation, linting, and automated synthesis."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "内置深度集成的 AI 助手，支持智能摘要、测验生成、语法修复及自动化知识合成。"
          }
        }
      }
    },
    "onboarding.step.aiLab.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "AI-Native Collaboration"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "AI 原生协作"
          }
        }
      }
    },
    "onboarding.step.graph.desc": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Discover hidden links between knowledge and visualize your thought trajectory via interactive 2D/3D graphs."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过交互式 2D/3D 图谱，直观洞察知识之间的隐藏关联，发现思想的成长轨迹。"
          }
        }
      }
    },
    "onboarding.step.graph.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Visual Knowledge Graph"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "可视化知识图谱"
          }
        }
      }
    },
    "onboarding.step.linking.desc": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use [[title]] syntax to create semantic links between pages, letting fragmented info flow and aggregate naturally."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用 [[标题]] 语法，在不同页面之间建立语义关联，让碎片化的信息自然流动、聚合。"
          }
        }
      }
    },
    "onboarding.step.linking.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Power of Backlinking"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "双向链接的力量"
          }
        }
      }
    },
    "onboarding.step.vault.desc": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Now, start entering your first piece of knowledge and let your wisdom take root in ZhiYu."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "现在，开始录入您的第一条知识，让您的智慧在“智宇”中生根发芽。"
          }
        }
      }
    },
    "onboarding.step.vault.title": {
