    "prompt.potentialLinks": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "你是一位专业的知识库架构师。\n任务：分析给定的文本，识别其中提到的、但尚未标记为 [[链接]] 的现有页面标题。\n\n要求：\n1. 仅返回文本中明确提到或高度相关的标题。\n2. 以 JSON 数组格式返回，例如: [\"标题1\", \"标题2\"]\n3. 不要返回任何解释。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你是一位专业的知识库架构师。\n任务：分析给定的文本，识别其中提到的、但尚未标记为 [[链接]] 的现有页面标题。\n\n要求：\n1. 仅返回文本中明确提到或高度相关的标题。\n2. 以 JSON 数组格式返回，例如: [\"标题1\", \"标题2\"]\n3. 不要返回任何解释。"
          }
        }
      }
    },
    "prompt.queryRewrite": {
      "extractionState": "manual",
      "localizations": {
