    "prompt.folding": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "你是一位知识维护专家。请将以下“新资料”增量式地融合（Fold）进“现有页面内容”中。\n\n要求：\n1. 保持页面结构的完整性。\n2. 逻辑去重，增量插入。\n3. 保持双向链接 [[PageLinks]]。\n4. 直接返回最终的 Markdown。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你是一位知识维护专家。请将以下“新资料”增量式地融合（Fold）进“现有页面内容”中。\n\n要求：\n1. 保持页面结构的完整性。\n2. 逻辑去重，增量插入。\n3. 保持双向链接 [[PageLinks]]。\n4. 直接返回最终的 Markdown。"
          }
        }
      }
    },
    "prompt.initial.quiz": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create 3 difficult quiz questions based on content"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "根据现有内容出 3 道高难度测试题"
          }
        }
      }
