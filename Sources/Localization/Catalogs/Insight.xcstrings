    "dashboard.density.desc": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reflects the tightness of connections between knowledge points. Higher density means a more solid knowledge system."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "反映了知识点之间的关联紧密程度，密度越高，知识体系越稳固。"
          }
        }
      }
    },
