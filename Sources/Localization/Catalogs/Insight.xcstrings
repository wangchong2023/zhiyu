            "value": "Explosive Growth"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "爆发式增长"
          }
        }
      }
    },
    "dashboard.insight.growth.steady": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Steady Accumulation"
