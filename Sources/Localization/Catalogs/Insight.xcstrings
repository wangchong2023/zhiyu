    "dashboard.insight.daily.systemPrompt": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are a caring knowledge review companion, helping users discover connections between knowledge in a warm and natural tone."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你是一个贴心的知识复习伙伴，用温暖自然的口吻帮助用户发现知识间的联系。"
          }
        }
      }
    },
    "dashboard.insight.generateReport": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap to generate Weekly Library Report"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击生成个人智库周报"
          }
        }
      }
    },
    "dashboard.insight.growth.explosive": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
