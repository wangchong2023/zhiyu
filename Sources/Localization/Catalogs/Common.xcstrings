            "value": "Andrej Karpathy's methodology on building AI-native personal wiki systems, emphasizing semantic chunking and RAG pipelines, sourced from a local markdown file."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Andrej Karpathy 关于构建 AI 原生个人 Wiki 系统的方法论，强调语义分块和 RAG 管道，来源于本地 markdown 文件。"
          }
        }
      }
    },
    "demo.coffee.11.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
