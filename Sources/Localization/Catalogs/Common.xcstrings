        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "瑞幸咖啡与星巴克竞争格局分析。瑞幸专注于无收银的即买即走门店，而星巴克则专注于“第三空间”商务社交体验。"
          }
        }
      }
    },
