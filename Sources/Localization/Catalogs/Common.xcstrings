      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The Ebbinghaus forgetting curve shows that memory retention declines quickly over time, so spaced repetition is essential."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "艾宾浩斯遗忘曲线表明，人的遗忘速度是先快后慢的，因此在 20 分钟、1 小时、9 小时后进行间隔重复至关重要。"
          }
        }
      }
    },
