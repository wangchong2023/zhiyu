          }
        }
      }
    },
    "demo.coffee.11.content": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Luckin Coffee vs Starbucks competitive landscape analysis. Luckin's focus on cashierless grab-and-go outlets vs Starbucks' 'Third Space' business social experience, retrieved from local market PDF report."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "瑞幸与星巴克竞品格局分析报告。深入对比了瑞幸咖啡极简快取与星巴克“第三空间”的商业定位差异。"
          }
        }
      }
    },
    "demo.fallback.methodology": {
