    "schema.entity.prompt": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "For entity types, extract a clear definition and at least 3 core attributes. Establish bidirectional links with other entities."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对于实体类型，必须提取其明确的定义，并列出至少3个核心属性。必须发现并建立与其他实体的双向链接。"
          }
        }
      }
    },
    "schema.entity.template": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "# {title}\n\n## Definition\n{definition}\n\n## Core Attributes\n- Attr 1: \n- Attr 2: \n\n## Related Entities\n- [[Related Entity]]"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "# {title}\n\n## 定义\n{definition}\n\n## 核心属性\n- 属性1: \n- 属性2: \n\n## 关联实体\n- [[相关实体]]"
          }
        }
      }
    },
