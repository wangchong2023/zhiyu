      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Andrej Karpathy's methodology on building AI-native personal wiki systems, emphasizing semantic chunking and RAG pipelines."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Andrej Karpathy 关于构建 AI 原生个人 Wiki 系统的的方法论，强调语义分块与 RAG 管道。"
          }
        }
      }
    },
    "demo.fallback.workflow": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Knowledge management workflows: capture, chunk, retrieve, synthesize. Integrate daily tools into a unified knowledge loop."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "知识管理工作流：捕获、分块、检索、合成。将日常工具集成到统一的知识闭环中。"
          }
        }
      }
    },
    "demo.fallback.luckin": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Luckin Coffee vs Starbucks competitive landscape analysis. Luckin's focus on cashierless grab-and-go outlets vs Starbucks' 'Third Space' business social experience."
