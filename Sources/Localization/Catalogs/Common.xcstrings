    "schema.concept.prompt": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "For concept types, focus on explaining underlying principles and practical application scenarios. Content should be concise and professional."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对于概念类型，重点解释其底层原理和实际应用场景。内容要求高度概括且专业。"
          }
        }
      }
    },
    "schema.concept.template": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "# {title}\n\n## Principles\n{theory}\n\n## Application Scenarios\n- Scenario 1\n- Scenario 2"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "# {title}\n\n## 原理\n{theory}\n\n## 应用场景\n- 场景1\n- 场景2"
          }
        }
      }
    },
