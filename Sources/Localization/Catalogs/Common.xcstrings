    "demo.pkm.1.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Personal Knowledge Graph Guide"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "个人知识图谱指南"
          }
        }
      }
    },
    "demo.pkm.1.content": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A personal knowledge graph is not just a collection of notes, but the core of building a personal web-like second brain. This is typically constructed by categorizing notes into [[Theme]] and [[Entry]], and building [[Connection]] between them. For details on physical Markdown import, please refer to the associated file `personal_knowledge_graph_guide.md`."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "个人知识图谱不仅是简单的笔记收集，更是建立个人网状外脑的核心。这通常通过将笔记分类为[[主题]]与[[词条]]，并在它们之间建立[[关联]]来构建。物理导入的 Markdown 详情参见关联物理文件 `个人知识图谱指南.md`。"
          }
        }
      }
    },
    "demo.pkm.2.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Entry: What is a Neuron"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "词条：什么是神经元"
          }
        }
      }
    },
    "demo.pkm.2.content": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An entry is a core note type in a knowledge graph, focusing on specific definitions, concepts, names, events, and factual attributes. Take the \"Neuron\" entry as an example, it is typically connected to a [[Theme]] related to \"Brain Science\"."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "词条是知识图谱中一种核心的笔记类型，专注于具体的定义、概念、人名、事件及事实属性。以“神经元”词条为例，它通常会与“脑科学”相关的[[主题]]进行关联。"
          }
        }
      }
    },
    "demo.pkm.3.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cross-Domain Hub Guide"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "跨领域笔记枢纽指南"
          }
        }
      }
    },
    "demo.pkm.3.content": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A cross-domain hub is a bridge page connecting different [[Knowledge Domain]]s. If it is removed, two originally disconnected knowledge domains will fall apart. It is a key hub for bridging interdisciplinary insights."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "跨领域笔记枢纽是连接不同[[知识领域]]的桥梁页面。如果它没了，两个本来不相连的知识领域就会断开，是联通跨界认知的重要枢纽。"
          }
        }
      }
    },
    "demo.pkm.4.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Voice Memo: Unlinked Note"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "语音速记的未关联笔记"
          }
        }
      }
    },
    "demo.pkm.4.content": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An unlinked note is a page that has no connection lines at all, usually an inspiration draft you wrote down on the fly. Connecting it can help it integrate into your knowledge web."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "未关联笔记是完全没有建立任何链接线的页面，通常是你随手记下的灵感草稿。帮它建立关联能让它融入你的知识网络。"
          }
        }
      }
    },
    "demo.pkm.5.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Progressive Summarization Comparison"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "渐进式总结对比分析"
          }
        }
      }
    },
    "demo.pkm.5.content": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Compare and analyze traditional note-taking with ZhiYu's web-like knowledge graph. Introduce how to use progressive summarization highlighting to make notes easy to retrieve and connect."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对比分析传统的记笔记与智宇的网状知识图谱。介绍如何利用渐进总结高亮，使笔记易于检索 and 关联。"
          }
        }
      }
    },
    "demo.coffee.1.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Luckin vs Starbucks Comparison Report"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "瑞幸与星巴克商业对比报告"
          }
        }
      }
    },
    "demo.coffee.1.content": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Compare and analyze the business models and cost structures of two coffee giants in the domestic market. Provide decision support for our new cafe planning through detailed data assessment. The physical imported file is `luckin_market_report.pdf`."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "对比分析两家咖啡巨头在国内市场的运营模式与成本结构。通过细致的数据评估，为我们新设立的咖啡馆规划提供决策支持。物理导入文件为 `瑞幸与星巴克商业对比报告.pdf`。"
          }
        }
      }
    },
    "demo.coffee.2.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Entry: What is Coffee Roasting Level"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "词条：什么是咖啡豆烘焙度"
          }
        }
      }
    },
    "demo.coffee.2.content": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An entry focuses on specific coffee definitions. For example, the roasting level determines the flavor tone of coffee beans, divided into light, medium, and dark roasts, each with different physical and chemical changes. This entry is imported via smart OCR physical scanning."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "词条专注于具体的咖啡定义。例如，烘焙度决定了咖啡豆的风味基调，分为浅焙、中焙和深焙，各具不同的物理 and 化学变化。本词条通过智能 OCR 物理扫描导入。"
          }
        }
      }
    },
    "demo.coffee.3.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Coffee Chain Site Selection Planning"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "咖啡连锁行业选址规划"
          }
        }
      }
    },
    "demo.coffee.3.content": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The theme focuses on the methodology and evaluation logic of site selection planning. Introduce core planning steps such as business district traffic, rent models, and customer profiling."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "主题侧重于选址规划的方法论与评估逻辑。介绍商圈流量、租金模型及人群画像等核心规划步骤。"
          }
        }
      }
    },
    "demo.coffee.4.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Voice Memo: Equipment Procurement List"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "语音速记：咖啡设备采购清单"
          }
        }
      }
    },
    "demo.coffee.4.content": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Quickly record the procurement list and budget through voice narration, such as commercial espresso machines, grinders, and water purification equipment procurement planning. The physical file is a `.mp3` recording converted from voice."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通过语音口述快速记录的采购清单和预算，例如商用意式机、磨豆机和净水设备采购规划。物理文件为语音转换的 `.mp3` 录音文件。"
          }
        }
      }
    },
    "demo.coffee.5.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Coffee Shop Daily Operations Manual"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "咖啡店日常运营手册"
          }
        }
      }
    },
    "demo.coffee.5.content": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Explain in detail the daily opening workflow, hygiene standards, and service scripts of coffee shops. This is an important guidance for standardized operation of coffee shops."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "详细讲解咖啡门店的日常开店流程、卫生标准以及服务话术。这是咖啡店标准化运营的重要指导。"
          }
        }
      }
    },
