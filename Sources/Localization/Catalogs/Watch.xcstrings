    "watch.briefing.noNewContent": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No new knowledge recorded today. Time to relax!"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
