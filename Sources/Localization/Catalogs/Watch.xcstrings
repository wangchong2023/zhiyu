    "watch.briefing.promptTemplate": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Based on the recently entered notes, generate a short, colloquial, and voice-broadcast-friendly daily knowledge briefing. Requirements: Remove all Markdown marks, use natural language transitions, and sound like a knowledge steward talking to me. Content:\n%@"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "根据以下最近录入的笔记，生成一段简短、口语化、适合用语音播报的每日知识简报。\n要求：去除所有 Markdown 标记，使用自然语言的转折词，像一位知识管家在对我说话。\n内容：\n%@"
          }
        }
      }
    },
    "watch.briefing.systemPrompt": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You are a professional knowledge management voice announcer."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你是一个专业的知识管理语音播报员。"
          }
        }
      }
    },
    "watch.briefing.failed": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Failed to generate briefing. Please check your network or model settings."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "生成简报失败，请检查网络或模型设置。"
          }
        }
      }
    }
