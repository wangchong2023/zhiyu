    "plugin.error.sandboxBlocked": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sandbox Intercepted: High-risk system/network keywords detected in the plugin script. Execution blocked!"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "沙盒拦截：检测到插件脚本中包含高危底层系统/网络操作关键字，执行被阻断！"
          }
        }
      }
    },
    "plugin.error.dlpScriptBlocked": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "DLP Intercepted: High-risk data exfiltration keywords detected in the plugin script. Execution blocked!"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "DLP 拦截：检测到插件脚本中包含高危数据外泄(Data Exfiltration)网络连接关键字，执行被阻断！"
          }
        }
      }
    },
    "plugin.error.dlpFetchBlocked": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "DLP Intercepted: This plugin attempted unauthorized external network transmission to (%@) (fetch)"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "DLP 拦截：此插件试图发起向未授权外网域名(%@)的网络传输(fetch)"
          }
        }
      }
    },
