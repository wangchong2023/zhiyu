    "plugin.safeMode.warning.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turning off Safe Mode allows loading unverified local plugins. These plugins may access your private data or system resources. Are you sure you want to proceed?"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭安全模式后，系统将允许加载未经审核的本地插件。这些插件可能获取您的隐私数据或系统资源访问权限。建议仅在信任插件来源时关闭。确认关闭吗？"
          }
        }
      }
    },
