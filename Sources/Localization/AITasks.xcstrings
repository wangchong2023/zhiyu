    "aitask.empty.desc": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Progress of all AI scans, synthesis, and health check tasks will be shown here."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "所有 AI 扫描、导出合成和健康检查任务的进度都将在这里显示。"
          }
        }
      },
      "extractionState": "manual"
    },
    "aitask.empty.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No Active Tasks"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当前无活跃任务"
          }
        }
      },
      "extractionState": "manual"
    },
    "aitask.emptyHint": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This shows long-running background tasks like synthesis, full-vault scanning, etc. You can start tasks from the Labs in page details."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此处展示长耗时的异步后台任务，如知识合成、全库扫描等。您可以在页面详情的实验室栏中启动任务。"
          }
        }
      },
      "extractionState": "manual"
    },
