    "backup.restoreMessage": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Are you sure you want to restore from this backup? Current data will be replaced. A safety backup will be created first."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定要从此备份恢复吗？当前数据将被替换，恢复前会自动创建安全备份。"
          }
        }
      }
    },
