# .gitignore for ZhiYu (Swift/Xcode/macOS)

# Xcode
xcuserdata/
MostRecentCompletionIndex
*.xcuserstate
*.xcscmblueprint
*.xccheckout
*.xcworkspace/contents.xcworkspacedata
*.xcworkspace/xcuserdata/
*.xcodeproj/project.xcworkspace/
*.xcodeproj/xcuserdata/
DerivedData/
*.moved-aside
*.p_t

# Build results
build/

# Swift Package Manager
.build/
.swiftpm/

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Other
*.log
scratch/
env/

# Claude Code
.codegraph/

# Temporary log/pid files
/tmp/*.log
/tmp/*.pid
/tmp/mock_*.pid

# 插件源文件 — 仅在 Tools/Plugins/ 下管理，禁止根目录散落
/*.zyplugin

# VS Code 统计工具输出
.VSCodeCounter/

# 第三方 AI 助手遗留
.workbuddy/

# Python 缓存
__pycache__/

# 临时测试数据目录
Configs/
zhiyu-releases/
